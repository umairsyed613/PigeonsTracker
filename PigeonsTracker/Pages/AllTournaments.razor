@page "/AllTournaments"
@inject IStringLocalizer<Language> Localizer
@inject IPublicTournamentService PublicTournamentService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PagesBase>
    <div class="d-flex flex-column">
        <MyPageTitle Text="@Localizer["TournamentType1"]"></MyPageTitle>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-3">@_error</MudAlert>
        }

        @if (_isLoading)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true"></MudProgressCircular>
        }
        else if (_publicTournaments.Count == 0)
        {
            <p>@Localizer["NoRecords"]</p>
        }
        else
        {
            <div class="d-flex flex-column overflow-y-auto" style="height: calc(100vh - 220px) !important;">
                @foreach (var data in _publicTournaments)
                {
                    <div class="d-flex flex-row align-items-center w-100 p-3 border-bottom shadow-sm rounded mb-1" style="background: #e9e3f5">
                        <div class="text-muted">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-trophy" viewBox="0 0 16 16">
                                <path d="M2.5.5A.5.5 0 0 1 3 0h10a.5.5 0 0 1 .5.5c0 .538-.012 1.05-.034 1.536a3 3 0 1 1-1.133 5.89c-.79 1.865-1.878 2.777-2.833 3.011v2.173l1.425.356c.194.048.377.135.537.255L13.3 15.1a.5.5 0 0 1-.3.9H3a.5.5 0 0 1-.3-.9l1.838-1.379c.16-.12.343-.207.537-.255L6.5 13.11v-2.173c-.955-.234-2.043-1.146-2.833-3.012a3 3 0 1 1-1.132-5.89A33.076 33.076 0 0 1 2.5.5zm.099 2.54a2 2 0 0 0 .72 3.935c-.333-1.05-.588-2.346-.72-3.935zm10.083 3.935a2 2 0 0 0 .72-3.935c-.133 1.59-.388 2.885-.72 3.935zM3.504 1c.007.517.026 1.006.056 1.469.13 2.028.457 3.546.87 4.667C5.294 9.48 6.484 10 7 10a.5.5 0 0 1 .5.5v2.61a1 1 0 0 1-.757.97l-1.426.356a.5.5 0 0 0-.179.085L4.5 15h7l-.638-.479a.501.501 0 0 0-.18-.085l-1.425-.356a1 1 0 0 1-.757-.97V10.5A.5.5 0 0 1 9 10c.516 0 1.706-.52 2.57-2.864.413-1.12.74-2.64.87-4.667.03-.463.049-.952.056-1.469H3.504z"/>
                            </svg>
                        </div>
                        <div class="d-flex align-items-center mx-2 flex-grow-1 px-2 cursor-btn" @onclick='() => NavigationManager.NavigateTo($"/ViewPublicTournament/{data.Id}")'>
                            <div class="d-flex flex-column w-100">
                                <h5>@data.Name</h5>
                                <div class="d-flex flex-row flex-wrap justify-content-start text-muted fs-0-5">
                                    <span>Start : @data.StartsFrom.ToString("dd MMM yyyy")</span>
                                    <span class="ms-2">End : @data.EndTo.ToString("dd MMM yyyy")</span>
                                    <span class="ms-2">Lofts : @data.Lofts.Count</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</PagesBase>

<MudFab Color="Color.Primary" Class="btnFloating animate__animated animate__slideInUp" StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => NavigationManager.NavigateTo("/CreatePublicTournament"))"/>

@code{

    [Inject]
    private Blazor.Analytics.IAnalytics Analytics { get; set; }

    private bool _isLoading = true;
    private string _error = string.Empty;
    private List<PublicTournament> _publicTournaments = [];

    protected override async Task OnInitializedAsync()
    {
        await Analytics.TrackEvent("AllTournament", 1);
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        _error = string.Empty;

        try
        {
            _publicTournaments = await PublicTournamentService.GetAllPublicTournaments();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add("Failed to load public tournaments", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

}